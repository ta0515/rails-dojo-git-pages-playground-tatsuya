{
  "name": "Git Pages Playground",
  "image": "mcr.microsoft.com/devcontainers/python:3.14-bookworm",
  "remoteUser": "vscode",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Git Pages Preview",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "python3 --version && git --version"
}
